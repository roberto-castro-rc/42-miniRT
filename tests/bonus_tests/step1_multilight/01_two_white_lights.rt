# Step 1 Test: Two white lights from different angles
# MANDATORY: Only 1st light used → one-sided illumination
# BONUS:     Both lights used → scene lit from both sides
A 0.1 255,255,255
C 0,3,-12 0,-0.1,1 70

L -8,8,-5  0.6 255,255,255
L  8,8,-5  0.6 255,255,255

sp 0,1,5 3 200,50,50
pl 0,-1,0 0,1,0 180,180,180
