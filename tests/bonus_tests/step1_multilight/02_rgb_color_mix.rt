# Step 1 Test: RGB colored lights on white sphere
# MANDATORY: Only 1st red light → sphere appears red
# BONUS:     All 3 lights → RGB mixing → white center, colored edges
A 0.05 255,255,255
C 0,5,-15 0,-0.15,1 60

L -6,6,-3  0.7 255,0,0
L  6,6,-3  0.7 0,255,0
L  0,6,8   0.7 0,0,255

sp 0,1,5 4 255,255,255
pl 0,-2,0 0,1,0 200,200,200
